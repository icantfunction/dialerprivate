# AWS credentials can come from ~/.aws/credentials, environment variables,
# or an attached IAM role. Only the Connect settings below are required here.
AWS_REGION=us-east-1
CONNECT_INSTANCE_ID=YOUR_CONNECT_INSTANCE_ID
CONNECT_CONTACT_FLOW_ID=YOUR_CONTACT_FLOW_ID
SOURCE_PHONE_NUMBER=+15551234567
PORT=8787
